<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">


    <filter>
        <filter-name>AuthAccessFilter</filter-name>
        <filter-class>com.zentora.nike_x.middleware.AuthAccessFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthAccessFilter</filter-name>
        <url-pattern>/sign-up.html</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthAccessFilter</filter-name>
        <url-pattern>/sign-in.html</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthAccessFilter</filter-name>
        <url-pattern>/verify-email.html</url-pattern>
    </filter-mapping>


    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.zentora.nike_x.middleware.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>UserFilter</filter-name>
        <filter-class>com.zentora.nike_x.middleware.UserAccessFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>UserFilter</filter-name>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>
    <servlet>
        <servlet-name>Jersey Web Application</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>jakarta.ws.rs.Application</param-name>
            <param-value>com.zentora.nike_x.config.AppConfig</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>Jersey Web Application</servlet-name>
        <url-pattern>/api/*</url-pattern>
    </servlet-mapping>
    
    <session-config>
        <session-timeout>60</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <!-- In production, if using HTTPS, set <secure>true</secure> here -->
        </cookie-config>
    </session-config>
</web-app>